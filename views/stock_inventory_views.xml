<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_custom_stock_inventory_tree" model="ir.ui.view">
        <field name="name">custom_stock.inventory.tree</field>
        <field name="model">custom_stock.inventory</field>
        <field name="arch" type="xml">
            <list decoration-info="state == 'draft'" decoration-success="state == 'done'">
                <field name="name"/>
                <field name="date"/>
                <field name="location_id"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_custom_stock_inventory_form" model="ir.ui.view">
        <field name="name">custom_stock.inventory.form</field>
        <field name="model">custom_stock.inventory</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <field name="state" widget="statusbar" statusbar_visible="draft,confirmed,done"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Inventory Reference..."/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="location_id"/>
                        </group>
                        <group>
                            <field name="date"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_custom_stock_inventory" model="ir.actions.act_window">
        <field name="name">Inventory</field>
        <field name="res_model">custom_stock.inventory</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_custom_stock_inventory" name="Inventory" parent="menu_custom_stock_root" action="action_custom_stock_inventory" sequence="20"/>
</odoo>
