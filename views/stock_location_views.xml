<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_custom_stock_location_tree" model="ir.ui.view">
        <field name="name">custom_stock.location.tree</field>
        <field name="model">custom_stock.location</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="code"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_custom_stock_location_form" model="ir.ui.view">
        <field name="name">custom_stock.location.form</field>
        <field name="model">custom_stock.location</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="code"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_custom_stock_location" model="ir.actions.act_window">
        <field name="name">Locations</field>
        <field name="res_model">custom_stock.location</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_custom_stock_root" name="Custom Stock" sequence="10"/>
    <menuitem id="menu_custom_stock_location" name="Locations" parent="menu_custom_stock_root" action="action_custom_stock_location" sequence="10"/>
</odoo>
